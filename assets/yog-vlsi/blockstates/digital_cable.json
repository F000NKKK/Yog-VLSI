{
  "multipart": [
    { "apply": { "model": "yog-vlsi:block/digital_cable" } },
    { "when": { "north": "true" }, "apply": { "model": "yog-vlsi:block/digital_cable_arm" } },
    { "when": { "south": "true" }, "apply": { "model": "yog-vlsi:block/digital_cable_arm", "y": 180 } },
    { "when": { "west": "true" },  "apply": { "model": "yog-vlsi:block/digital_cable_arm", "y": 270 } },
    { "when": { "east": "true" },  "apply": { "model": "yog-vlsi:block/digital_cable_arm", "y": 90 } },
    { "when": { "up": "true" },    "apply": { "model": "yog-vlsi:block/digital_cable_arm", "x": 270 } },
    { "when": { "down": "true" },  "apply": { "model": "yog-vlsi:block/digital_cable_arm", "x": 90 } }
  ]
}
